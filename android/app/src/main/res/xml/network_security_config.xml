<?xml version="1.0" encoding="utf-8"?>
<!-- 🔒 SECURITY: Network Security Configuration for UniTransit -->
<network-security-config>
    <!-- Allow cleartext for local development only in debug builds -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- OSRM Routing API (public, uses HTTP) -->
        <domain includeSubdomains="true">router.project-osrm.org</domain>
        <!-- OpenStreetMap Tile Server (uses HTTP for map tiles) -->
        <domain includeSubdomains="true">tile.openstreetmap.org</domain>
        <!-- Local development server -->
        <domain includeSubdomains="false">192.168.100.4</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>

    <!-- 🔒 Default: Block cleartext (HTTP) traffic for all other domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
